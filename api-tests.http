### Variabili Globali
@baseUrl = http://localhost:4000/api

#########################################
### 1. AUTENTICAZIONE E SESSIONE
#########################################

### Login Utente Cittadino
# @name userLogin
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "username": "user1",
  "password": "password1"
}

### Login Amministratore
# @name adminLogin
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "username": "admin",
  "password": "adminpass",
  "isAdminLogin": true
}

### Verifica Sessione Corrente (usa i cookie salvati)
GET {{baseUrl}}/auth/me
x-admin-request: true

### Logout
POST {{baseUrl}}/auth/logout
Content-Type: application/json
x-admin-request: true


#########################################
### 2. GESTIONE UTENTI (ADMIN ONLY)
#########################################

### Elenco tutti gli utenti
GET {{baseUrl}}/auth/users
x-admin-request: true

### Crea un nuovo utente
POST {{baseUrl}}/auth/users
Content-Type: application/json
x-admin-request: true

{
  "username": "test.user",
  "password": "password123",
  "role": "user"
}

### Elimina un utente (cambia l'ID con uno esistente)
DELETE {{baseUrl}}/auth/users/3
x-admin-request: true


#########################################
### 3. GESTIONE AREE (PARCHEGGI)
#########################################

### Elenco tutte le aree e disponibilità
GET {{baseUrl}}/areas

### Crea nuova area (Admin)
POST {{baseUrl}}/areas
Content-Type: application/json
x-admin-request: true

{
  "id": "C9",
  "name": "Parcheggio Nord",
  "capacity": 50
}

### Elimina un'area (Admin)
DELETE {{baseUrl}}/areas/C9
x-admin-request: true


#########################################
### 4. PRENOTAZIONI E ANALYTICS
#########################################

### Crea una prenotazione (User)
POST {{baseUrl}}/bookings
Content-Type: application/json

{
  "areaId": "A1"
}

### Elenco prenotazioni proprie (User)
# Cambia l'ID con quello dell'utente loggato
GET {{baseUrl}}/bookings/my/1

### Elenco globale prenotazioni (Admin)
GET {{baseUrl}}/bookings/all
x-admin-request: true

### Statistiche giornaliere 30gg (Admin)
GET {{baseUrl}}/bookings/stats/30days
x-admin-request: true

### Trend settimanale per grafico (Admin)
GET {{baseUrl}}/bookings/trend/7days
x-admin-request: true


#########################################
### 5. AZIONI DI MANUTENZIONE (ADMIN)
#########################################

### Svuota tutti i parcheggi (scadenza immediata)
POST {{baseUrl}}/bookings/management/expire-all
x-admin-request: true

### Reset totale cronologia (CANCELLA TUTTO)
POST {{baseUrl}}/bookings/management/clear-history
x-admin-request: true
